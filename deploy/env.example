# Copy to /opt/gong/<env>/.env on the server, fill in real values, chmod 600.
# This file holds ALL runtime secrets. It stays on the host and is never in Git
# or GitHub Actions. CI only supplies SSH + the immutable IMAGE ref.

# --- Ingress -----------------------------------------------------------------
DOMAIN=staging.gong.example.org          # Caddy serves + auto-TLS this hostname

# --- App ---------------------------------------------------------------------
CONTAINER_NAME=production                # any non-dev value; libs/utils.environ maps it to "server"
DATA_DIR=/app/data                       # persistent volume mount (see compose app_data)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- PostgreSQL (db service) -------------------------------------------------
POSTGRES_USER=gong
POSTGRES_PASSWORD=CHANGE_ME_strong
POSTGRES_DB=gong
DATABASE_URL=postgresql://gong:CHANGE_ME_strong@db:5432/gong

# --- MinIO (minio service) ---------------------------------------------------
MINIO_ROOT_USER=gongminio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=gongminio                # defaults to MINIO_ROOT_USER if unset
MINIO_SECRET_KEY=CHANGE_ME_strong         # defaults to MINIO_ROOT_PASSWORD if unset
MINIO_SECURE=false                        # in-cluster traffic is plain HTTP
