# Self-signed origin TLS (`tls internal`): public TLS is terminated by Cloudflare
# (orange cloud) with SSL mode "Full", which connects to this origin over HTTPS and
# accepts the self-signed cert. No ACME, so no dependency on the front HAProxy for
# Let's Encrypt challenges. Site blocks are independent — one app down only 502s its
# own domain. Upstreams are the compose-stable container names `gong-<env>-app-1`.

campus-gong.dhamma.org {
	tls internal
	encode zstd gzip
	reverse_proxy gong-production-app-1:8000
}

staging.campus-gong.dhamma.org {
	tls internal
	encode zstd gzip
	reverse_proxy gong-staging-app-1:8000
}
